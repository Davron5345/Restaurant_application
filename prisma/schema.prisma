generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String   @id @default(cuid())
  date      DateTime // Дата проведения операции
  type      String   // "INCOME" (Приход) или "EXPENSE" (Расход)
  article   String   // Статья операции: "Терминал", "Поставщики", "А.Т. ойлик" и т.д.
  partner   String?  // От кого / Кому (может быть пустым)
  amount    Float    // Сумма
  comment   String?  // Комментарии
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  createdAt DateTime  @default(now())
}


model Supplier {
  id              String   @id @default(cuid())
  name            String   @unique
  inn             String?
  director        String?
  phone           String?
  rs              String?
  mfo             String?
  bankAddress     String?
  bank            String?
  address         String?
  accountant      String?
  accountantPhone String?
  tgChatId        String?
  currency        String   @default("UZS") // "UZS" или "USD"
  transactions    Transaction[]
  isActive        Boolean  @default(true)
}

model Bank {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
}

model Category {
  id        String   @id @default(cuid())
  name      String
  type      String   // "INCOME" или "EXPENSE"
  isActive  Boolean  @default(true)

  @@unique([name, type])
}

model User {
  id        String   @id @default(cuid())
  name      String?
  phone     String   @unique
  password  String
  role      String   @default("CASHIER") // Роли: ADMIN, CASHIER, FOUNDER...
  branches  Branch[] @relation("UserBranches")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Branch {
  id          String   @id @default(cuid())
  name        String   @unique
  logo        String?
  tgChatId    String?
  tgBotToken  String?
  users       User[]   @relation("UserBranches")
  transactions Transaction[]
  isActive    Boolean  @default(true)
}
